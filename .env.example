# OptimusCert — environment configuration
# Copy this file to `.env` and adjust as needed, then run: docker compose up --build

# Port the web app is served on (open http://localhost:8080)
APP_PORT=8080

# ---- Data backend ----
# 'optimusdb' = store all data in OptimusDB's SQLite via its SQL-over-HTTP API (default in compose)
# 'sqlite'    = use a local embedded SQLite file (no OptimusDB needed)
DB_BACKEND=optimusdb
# Where the backend reaches OptimusDB. In compose this is the service name.
OPTIMUSDB_URL=http://optimusdb:8089
OPTIMUSDB_CONTEXT=swarmkb
# Host port mapped to OptimusDB's HTTP API (for direct access/debugging)
OPTIMUSDB_HTTP_PORT=18089
# How long the backend waits for OptimusDB to come up on start (x2s)
OPTIMUSDB_STARTUP_RETRIES=60

# Secret used to sign login tokens — change this to any random string
JWT_SECRET=please-change-this-to-something-random

# The default admin account created on first run
ADMIN_EMAIL=admin@exam.local
ADMIN_PASSWORD=admin123

# ---- AI-powered PDF import (optional) ----
# Get a key at https://console.anthropic.com. Leave blank to use the no-key structured parser only.
ANTHROPIC_API_KEY=
AI_MODEL=claude-3-5-sonnet-latest
